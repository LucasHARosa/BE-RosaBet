### RosaBet API — REST Client
### Extensão: REST Client (Huachao Mao)
### Após fazer login, copie o access_token e cole na variável @token abaixo

@base = http://localhost:8000
@token = SEU_TOKEN_AQUI

# ==========================================
# HEALTH CHECK
# ==========================================

### Health Check
GET {{base}}/health


# ==========================================
# FASE 3 — Auth
# ==========================================

### Cadastro de novo usuário
POST {{base}}/client
Content-Type: application/json

{
  "name": "Lucas Rosa",
  "email": "lucas@rosabet.com",
  "cpf": "12345678901",
  "password": "senha123",
  "phone": "11999999999"
}

###

### Login com usuário demo (já existe ao subir em development)
POST {{base}}/auth/login
Content-Type: application/json

{
  "username": "demo@rosabet.com",
  "password": "demo123"
}

###

### Meu perfil (requer token)
GET {{base}}/user/me
Authorization: Bearer {{token}}


# ==========================================
# FASE 4 — Eventos esportivos
# ==========================================

### Listar todos os eventos abertos (ao vivo + pré-jogo)
GET {{base}}/sport/open

###

### Listar eventos ao vivo (filtra no cliente a partir do mesmo endpoint)
# Dica: todos os eventos com is_live=true são os ao vivo
GET {{base}}/sport/open


# ==========================================
# FASE 6 — Apostas
# ==========================================

### Criar aposta simples
# POST {{base}}/bet
# Authorization: Bearer {{token}}
# Content-Type: application/json
#
# {
#   "value": 10.00,
#   "spend_from": "credits",
#   "accept_all_changes": false,
#   "only_accept_high": false,
#   "sports": [
#     {
#       "enet_code": "sr:match:10001",
#       "market_id": 1,
#       "odd_id": "1::1",
#       "option_id": "1",
#       "quotation": 1.85,
#       "is_live": true,
#       "specifier": null
#     }
#   ]
# }

### Listar minhas apostas
# GET {{base}}/bet
# Authorization: Bearer {{token}}

### Detalhe de uma aposta
# GET {{base}}/bet/ID_DA_APOSTA_AQUI
# Authorization: Bearer {{token}}


# ==========================================
# FASE 8 — Depósito
# ==========================================

### Criar depósito PIX
# POST {{base}}/deposit
# Authorization: Bearer {{token}}
# Content-Type: application/json
#
# {
#   "value": 100.00
# }

### Listar depósitos
# GET {{base}}/deposit
# Authorization: Bearer {{token}}


# ==========================================
# FASE 9 — Cassino
# ==========================================

### Tipos de jogos
# GET {{base}}/casino/games_type

### Jogos por categoria
# GET {{base}}/casino/games?type=slot
