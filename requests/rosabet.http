# ==========================================
# FASE 6 — Apostas
# ==========================================

### Criar aposta simples (Brasil vence 1x2)
POST {{base}}/bet
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "value": 10.00,
  "spend_from": "credits",
  "accept_all_changes": false,
  "only_accept_high": false,
  "sports": [
    {
      "enet_code": "sr:match:10001",
      "market_id": 1,
      "odd_id": "1::1",
      "option_id": "1",
      "quotation": 1.85,
      "is_live": true,
      "specifier": null
    }
  ]
}

###

### Criar aposta múltipla (2 seleções)
POST {{base}}/bet
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "value": 20.00,
  "spend_from": "credits",
  "accept_all_changes": true,
  "only_accept_high": false,
  "sports": [
    {
      "enet_code": "sr:match:10001",
      "market_id": 1,
      "odd_id": "1::1",
      "option_id": "1",
      "quotation": 1.85,
      "is_live": true,
      "specifier": null
    },
    {
      "enet_code": "sr:match:10005",
      "market_id": 1,
      "odd_id": "1::2",
      "option_id": "2",
      "quotation": 2.90,
      "is_live": false,
      "specifier": null
    }
  ]
}

###

### Listar minhas apostas
GET {{base}}/bet
Authorization: Bearer {{token}}

###

@betId = ID_DA_APOSTA_AQUI

### Detalhe de uma aposta
GET {{base}}/bet/{{betId}}
Authorization: Bearer {{token}}


# ==========================================
# FASE 8 — Depósito PIX
# ==========================================

### Verificar se é primeiro depósito (elegível para bônus)
GET {{base}}/deposit-welcome-verification
Authorization: Bearer {{token}}

###

### Criar depósito PIX — confirma automaticamente em ~10s
POST {{base}}/deposit
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "value": 100.00
}

###

### Criar depósito com bônus máximo (1º depósito: 100% até R$200)
POST {{base}}/deposit
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "value": 200.00
}

###

### Listar meus depósitos
GET {{base}}/deposit
Authorization: Bearer {{token}}


# ==========================================
# FASE 9 — Cassino
# ==========================================

### Tipos de jogos
# GET {{base}}/casino/games_type

### Jogos por categoria
# GET {{base}}/casino/games?type=slot
